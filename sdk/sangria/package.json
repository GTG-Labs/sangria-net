{
  "name": "sangria",
  "version": "0.1.0",
  "description": "Sangria payment network SDK for Express, Hono, and Fastify",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./express": {
      "import": "./dist/adapters/express.js",
      "types": "./dist/adapters/express.d.ts"
    },
    "./hono": {
      "import": "./dist/adapters/hono.js",
      "types": "./dist/adapters/hono.d.ts"
    },
    "./fastify": {
      "import": "./dist/adapters/fastify.js",
      "types": "./dist/adapters/fastify.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "echo 'No unit tests yet - SDK tests run from project root'",
    "test-server": "tsx --watch test-server/server.ts",
    "test-server:express": "tsx --watch test-server/server.ts",
    "test-server:hono": "tsx --watch test-server/server-hono.ts",
    "test-server:fastify": "tsx --watch test-server/server-fastify.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "benchmark": "echo 'TypeScript benchmarks not yet implemented'",
    "prepublishOnly": "npm run build && npm run type-check && npm run lint",
    "prepack": "npm run build"
  },
  "keywords": [
    "x402",
    "payments",
    "express",
    "hono",
    "fastify",
    "middleware"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Sangria Network",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GTG-Labs/sangria-net.git",
    "directory": "sdk/sangria"
  },
  "bugs": {
    "url": "https://github.com/GTG-Labs/sangria-net/issues"
  },
  "homepage": "https://github.com/GTG-Labs/sangria-net#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "fastify-plugin": "^5.1.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "hono": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.13",
    "@types/express": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "express": "^4.21.0",
    "fastify": "^5.8.3",
    "hono": "^4.12.12",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.0.0"
}
