{
  "name": "@sangria-sdk/core",
  "version": "0.1.2",
  "description": "Sangria payment network SDK for Express, Hono, Fastify, and Next.js",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./express": {
      "import": "./dist/adapters/express.js",
      "types": "./dist/adapters/express.d.ts"
    },
    "./hono": {
      "import": "./dist/adapters/hono.js",
      "types": "./dist/adapters/hono.d.ts"
    },
    "./fastify": {
      "import": "./dist/adapters/fastify.js",
      "types": "./dist/adapters/fastify.d.ts"
    },
    "./nextjs": {
      "import": "./dist/adapters/nextjs.js",
      "types": "./dist/adapters/nextjs.d.ts"
    }
  },
  "scripts": {
    "prepublishOnly": "tsc",
    "build": "tsc",
    "dev": "tsc --watch",
    "test-server": "tsx --watch test-server/server.ts",
    "test-server:express": "tsx --watch test-server/server.ts",
    "test-server:hono": "tsx --watch test-server/server-hono.ts",
    "test-server:fastify": "tsx --watch test-server/server-fastify.ts"
  },
  "keywords": [
    "x402",
    "payments",
    "express",
    "hono",
    "fastify",
    "nextjs",
    "middleware"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "fastify-plugin": "^5.1.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "hono": ">=4.0.0",
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@types/express": "^5.0.0",
    "express": "^4.21.0",
    "fastify": "^5.0.0",
    "hono": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@8.15.8+sha512.d1a029e1a447ad90bc96cd58b0fad486d2993d531856396f7babf2d83eb1823bb83c5a3d0fc18f675b2d10321d49eb161fece36fe8134aa5823ecd215feed392"
}
