{
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "env": {
    "node": true,
    "es2020": true
  },
  "globals": {
    "fetch": "readonly",
    "AbortSignal": "readonly",
    "URL": "readonly",
    "btoa": "readonly"
  },
  "rules": {
    "@typescript-eslint/no-unused-vars": "error",
    "no-unused-vars": "off"
  },
  "ignorePatterns": ["dist/", "node_modules/"]
}