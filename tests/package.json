{
  "name": "@sangria/comprehensive-test-suite",
  "version": "1.0.0",
  "description": "Comprehensive testing suite for Sangria SDK with full coverage and CI/CD",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "test": "pnpm test:core",
    "test:all": "pnpm test:core && pnpm test:e2e",
    "test:core": "pnpm test:unit && pnpm test:security",
    "test:unit": "pnpm test:unit:ts && pnpm test:unit:py",
    "test:unit:ts": "vitest run unit/typescript/ --reporter=verbose",
    "test:unit:py": "cd ../sdk/python && source venv/bin/activate && cd ../../tests && python -m pytest unit/python/ -v",
    "test:adapters": "echo 'Adapter tests temporarily disabled - see TODO.md'",
    "test:security": "vitest run security/ --reporter=verbose",
    "test:integration": "echo 'Integration tests use deterministic server - included in e2e'",
    "test:e2e": "vitest run e2e/ --reporter=verbose",
    "test:e2e:deterministic": "vitest run e2e/deterministic-payment-flow.test.ts --reporter=verbose",
    "test:cross-sdk": "echo 'Cross-SDK tests would be implemented when needed'",
    "test:performance": "echo 'Performance tests would be implemented when needed'",
    "test:ci": "pnpm lint && pnpm test:core && pnpm coverage:check",
    "test:quick": "pnpm test:core",
    "test:watch": "vitest watch",
    "lint": "pnpm lint:ts",
    "lint:ts": "cd ../sdk/sdk-typescript && pnpm lint",
    "lint:fix": "pnpm lint:fix:ts && pnpm lint:fix:py",
    "lint:fix:ts": "cd ../sdk/sdk-typescript && pnpm lint:fix",
    "lint:fix:py": "cd ../sdk/python && black . && isort .",
    "coverage": "pnpm coverage:unit && pnpm coverage:integration && pnpm coverage:e2e",
    "coverage:unit": "concurrently \"pnpm coverage:unit:ts\" \"pnpm coverage:unit:py\"",
    "coverage:unit:ts": "cd ../sdk/sdk-typescript && pnpm test:coverage",
    "coverage:unit:py": "cd ../sdk/python && source venv/bin/activate && cd ../../tests && python -m pytest unit/python/ --cov=sangria_sdk --cov-report=xml",
    "coverage:integration": "pnpm coverage:e2e",
    "coverage:e2e": "vitest run e2e/ --coverage",
    "coverage:combine": "vitest run --coverage",
    "coverage:check": "vitest run --coverage --reporter=verbose",
    "coverage:check:unit": "pnpm coverage:unit",
    "coverage:check:integration": "pnpm coverage:integration",
    "coverage:check:overall": "vitest run --coverage --reporter=verbose",
    "coverage:report": "vitest run --coverage --reporter=html",
    "coverage:badge": "vitest run --coverage --reporter=json",
    "benchmark": "echo 'Benchmarks would be implemented when needed'",
    "dev:setup": "pnpm dev:setup:ts && pnpm dev:setup:py",
    "dev:setup:ts": "cd ../sdk/sdk-typescript && pnpm install",
    "dev:setup:py": "cd ../sdk/python && python -m venv venv && source venv/bin/activate && pip install -e . && pip install pytest pytest-cov pytest-asyncio",
    "dev:services": "echo 'No Docker services needed - using MockSangriaServer'",
    "dev:services:stop": "echo 'No Docker services to stop'",
    "clean": "pnpm clean:coverage && pnpm clean:artifacts",
    "clean:coverage": "rm -rf coverage/ ../sdk/*/coverage/ ../sdk/*/htmlcov/ ../sdk/*/.coverage",
    "clean:artifacts": "rm -rf e2e/results/ e2e/screenshots/ e2e/videos/",
    "precommit": "pnpm lint && pnpm test:quick",
    "prepush": "pnpm test:all && pnpm coverage:check",
    "release:check": "pnpm test:ci && pnpm benchmark && pnpm security:audit",
    "security:audit": "pnpm security:audit:ts",
    "security:audit:ts": "cd ../sdk/sdk-typescript && pnpm audit"
  },
  "devDependencies": {
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^3.0.0",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "concurrently": "^8.2.2",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "fastify": "^5.8.3",
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.12",
    "lcov-parse": "^1.0.0",
    "viem": "^2.47.10",
    "vite": "^7.0.0",
    "vitest": "^4.1.3"
  },
  "keywords": [
    "sangria",
    "sdk",
    "testing",
    "coverage",
    "ci-cd",
    "payments",
    "web3"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/sangria-net.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/sangria-net/issues"
  },
  "homepage": "https://github.com/your-org/sangria-net#readme",
  "author": "Sangria Network",
  "license": "MIT",
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "decimal.js": "^10.6.0"
  }
}