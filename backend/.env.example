# Postgres connection string used by the Go backend.
#
# SSL modes explained:
#   sslmode=disable      → no encryption at all (local dev only)
#   sslmode=require      → encrypted, but doesn't verify who the server is
#   sslmode=verify-full  → encrypted AND verifies the server's certificate
#                          against trusted CAs. This is the most secure option. THIS IS WHAT WE SHOULD USE FOR THIS BACKEND
#
# sslrootcert=system tells the driver to use your OS's built-in CA
# certificates (e.g. /etc/ssl/certs) to verify the server, instead of
# needing a separate .pem file. Go's pgx driver supports this natively.
#
DATABASE_URL=

# Server port (required)
PORT=

# WorkOS configuration for session validation
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# JWT issuer for token validation (required).
# Use https://api.workos.com/ unless you have a custom WorkOS auth domain.
WORKOS_TOKEN_ISSUER=
# Webhook secret for signature verification (required for webhooks)
WORKOS_WEBHOOK_SECRET=

# CORS configuration - comma-separated list of allowed origins
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://myapp.com
ALLOWED_ORIGINS=

# Coinbase Developer Platform (CDP) credentials
CDP_API_KEY=
CDP_API_SECRET=
CDP_WALLET_SECRET=

# Platform fee configuration
# Percentage fee on each payment (0.5 = 0.5%)
PLATFORM_FEE_PERCENT=0.5
# Minimum fee in microunits (1000 = $0.001)
PLATFORM_FEE_MIN_MICROUNITS=1000

# Payment configuration
# Maximum value accepted for a single payment in microunits (1000000000000 = $1,000,000).
PAYMENT_MAX_MICROUNITS=1000000000000

# Withdrawal configuration
# Auto-approve threshold in microunits (200000000 = $200)
WITHDRAWAL_AUTO_APPROVE_THRESHOLD=200000000
# Minimum withdrawal amount in microunits (1000000 = $1.00)
WITHDRAWAL_MIN_AMOUNT=1000000
# Flat fee per withdrawal in microunits (0 = free)
WITHDRAWAL_FEE_FLAT=0

# x402 facilitator URL
# Testnet:    https://x402.org/facilitator
# Production: https://api.cdp.coinbase.com/platform/v2/x402
X402_FACILITATOR_URL=

# Resend API configuration for sending emails
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Rate limiter Configs
# Set RATE_LIMIT_DISABLED=true to bypass all limits in an emergency.
RATE_LIMIT_V1_PER_MIN=30
RATE_LIMIT_INTERNAL_PER_MIN=60
RATE_LIMIT_ADMIN_PER_MIN=100
RATE_LIMIT_INVITATIONS_PER_MIN=10
RATE_LIMIT_ACCEPT_INVITATION_PER_MIN=20
RATE_LIMIT_AUTH_FAILURES_PER_MIN=10
RATE_LIMIT_DISABLED=false

# WorkOS webhook source IP allowlist (comma-separated).
# Fail-closed: empty list rejects every webhook request.
# IPs from https://workos.com/docs/events/data-syncing/webhooks
WORKOS_WEBHOOK_ALLOWED_IPS=3.217.146.166,23.21.184.92,34.204.154.149,44.213.245.178,44.215.236.82,50.16.203.9,52.1.251.34,52.21.49.187,174.129.36.47
