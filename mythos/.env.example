# Go backend base URL. Required.
BACKEND_URL=http://localhost:8080
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3001/auth/callback

# WorkOS credentials — consumed by AuthKit internally (not in lib/env.ts).
WORKOS_CLIENT_ID=
WORKOS_API_KEY=

# Generate via: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=

# --- x402-pay demo route ----------------------------------------------------
# Optional. When set, overrides the request-derived origin in demo resource URLs.
MYTHOS_BASE_URL=

# Merchant API key the demo route uses to authenticate against the backend.
SANGRIA_SECRET_KEY=

# Buyer-side EOA address (the agent role in x402).
BUYER_ADDRESS=

# Buyer-side CDP credentials — used to sign payments AS the buyer.
# These are NOT the backend's CDP credentials; they're agent/wallet creds for
# the demo flow only.
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
CDP_WALLET_SECRET=
