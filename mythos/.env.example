WORKOS_CLIENT_ID=
WORKOS_API_KEY=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3001/auth/callback
WORKOS_COOKIE_PASSWORD=
WORKOS_COOKIE_NAME=mythos-session
BACKEND_URL=http://127.0.0.1:8080

# Newspaper demo — x402 payment flow
# BACKEND_URL above is reused; Mythos authenticates to the merchant endpoints
# with a merchant API key.
# Optional override for public Mythos base URL in payment resource links.
# If empty, the API route derives this from the incoming request origin.
MYTHOS_BASE_URL=
SANGRIA_SECRET_KEY=
# Buyer wallet address on CDP (must be funded with USDC on Base mainnet)
BUYER_ADDRESS=
# CDP API credentials (from https://portal.cdp.coinbase.com)
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
# CDP wallet secret (decrypts the buyer wallet's signing key)
CDP_WALLET_SECRET=
